{
  "expo": {
    "name": "サボれない習慣化アプリ",
    "slug": "saborenai-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "saboapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.inouesyo.saboapp",
      "infoPlist": {
        "NSCameraUsageDescription": "ペナルティ用の自撮り写真を撮影するために使用します。",
        "NSPhotoLibraryUsageDescription": "自撮り写真を保存するために使用します。",
        "NSUserNotificationsUsageDescription": "習慣のリマインダーとペナルティ通知を送信するために使用します.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.inouesyo.saboapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-camera",
      [
        "expo-notifications",
        {
          "color": "#FF6B6B"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "916ad348-d11a-42d2-b24e-64bf7c2252dd"
      }
    },
    "owner": "syoinoue"
  }
}
